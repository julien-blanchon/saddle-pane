theme-light\">\u003Cpre class=\"shiki github-light\" style=\"background-color:#fff;color:#24292e\" tabindex=\"0\">\u003Ccode>\u003Cspan class=\"line\">\u003Cspan style=\"color:#D73A49\">use\u003C/span>\u003Cspan style=\"color:#6F42C1\"> saddle_pane_interval\u003C/span>\u003Cspan style=\"color:#D73A49\">::\u003C/span>\u003Cspan style=\"color:#6F42C1\">IntervalValue\u003C/span>\u003Cspan style=\"color:#24292E\">;\u003C/span>\u003C/span>\n\u003Cspan class=\"line\">\u003C/span>\n\u003Cspan class=\"line\">\u003Cspan style=\"color:#D73A49\">fn\u003C/span>\u003Cspan style=\"color:#6F42C1\"> read_interval\u003C/span>\u003Cspan style=\"color:#24292E\">(store\u003C/span>\u003Cspan style=\"color:#D73A49\">:\u003C/span>\u003Cspan style=\"color:#6F42C1\"> Res\u003C/span>\u003Cspan style=\"color:#24292E\">&#x3C;\u003C/span>\u003Cspan style=\"color:#6F42C1\">PaneStore\u003C/span>\u003Cspan style=\"color:#24292E\">>) {\u003C/span>\u003C/span>\n\u003Cspan class=\"line\">\u003Cspan style=\"color:#D73A49\">    if\u003C/span>\u003Cspan style=\"color:#D73A49\"> let\u003C/span>\u003Cspan style=\"color:#6F42C1\"> Some\u003C/span>\u003Cspan style=\"color:#24292E\">(\u003C/span>\u003Cspan style=\"color:#6F42C1\">PaneValue\u003C/span>\u003Cspan style=\"color:#D73A49\">::\u003C/span>\u003Cspan style=\"color:#6F42C1\">Custom\u003C/span>\u003Cspan style=\"color:#24292E\">(boxed)) \u003C/span>\u003Cspan style=\"color:#D73A49\">=\u003C/span>\u003Cspan style=\"color:#24292E\"> store\u003C/span>\u003Cspan style=\"color:#D73A49\">.\u003C/span>\u003Cspan style=\"color:#6F42C1\">get_raw\u003C/span>\u003Cspan style=\"color:#24292E\">(\u003C/span>\u003Cspan style=\"color:#032F62\">\"Debug\"\u003C/span>\u003Cspan style=\"color:#24292E\">, \u003C/span>\u003Cspan style=\"color:#032F62\">\"Range\"\u003C/span>\u003Cspan style=\"color:#24292E\">) {\u003C/span>\u003C/span>\n\u003Cspan class=\"line\">\u003Cspan style=\"color:#D73A49\">        if\u003C/span>\u003Cspan style=\"color:#D73A49\"> let\u003C/span>\u00