:#F97583\">.\u003C/span>\u003Cspan style=\"color:#B392F0\">downcast_ref\u003C/span>\u003Cspan style=\"color:#F97583\">::\u003C/span>\u003Cspan style=\"color:#E1E4E8\">&#x3C;\u003C/span>\u003Cspan style=\"color:#B392F0\">IntervalValue\u003C/span>\u003Cspan style=\"color:#E1E4E8\">>() {\u003C/span>\u003C/span>\n\u003Cspan class=\"line\">\u003Cspan style=\"color:#B392F0\">            println!\u003C/span>\u003Cspan style=\"color:#E1E4E8\">(\u003C/span>\u003Cspan style=\"color:#9ECBFF\">\"Range: {}..{}\"\u003C/span>\u003Cspan style=\"color:#E1E4E8\">, interval\u003C/span>\u003Cspan style=\"color:#F97583\">.\u003C/span>\u003Cspan style=\"color:#E1E4E8\">min, interval\u003C/span>\u003Cspan style=\"color:#F97583\">.\u003C/span>\u003Cspan style=\"color:#E1E4E8\">max);\u003C/span>\u003C/span>\n\u003Cspan class=\"line\">\u003Cspan style=\"color:#E1E4E8\">        }\u003C/span>\u003C/span>\n\u003Cspan class=\"line\">\u003Cspan style=\"color:#E1E4E8\">    }\u003C/span>\u003C/span>\n\u003Cspan class=\"line\">\u003Cspan style=\"color:#E1E4E8\">}\u003C/span>\u003C/span>\u003C/code>\u003C/pre>\u003C/div>\n\t\t\t\t\u003C/div>\u003Cp>Or observe changes:\u003C/p>\n\u003Cdiv class=\"code-block\" data-code=\"fn on_change(ev: On\u003CPaneChanged>) {\n    if let PaneValue::Custom(ref boxed) = ev.event().value {\n        if let Some(interval) = boxed.0.as_any().downcast_ref::\u003CIntervalValue>() {\n            info!(&quot;{}: {}..{}&quot;, ev.event().field, interval.min, interval.max);\n        }\n    }\n}\" data-language=\"rust\">\n\t\t\t\t\t\u003Cdiv class=\"shiki-theme-light\">\u003Cpre class=\"shiki github-light\" style=\"background-color:#fff;color:#24292e\" tabindex=\"0\">\u003Ccode>\u003Cspan class=\"line\">\u003Cspan style=\"color:#D73A49\">fn\u003C/span>\u003Cspan style=\"color:#6F42C1\"> on_change\u003C/span>\u003Cspan style=\"color:#24292E\">(ev\u003C/span>\u003Cspan style=\"color:#D73A49\">:\u003C/span>\u003Cspan style=\"color:#6F42C1\"> On\u003C/span>\u003Cspan style=\"color:#